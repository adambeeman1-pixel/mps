{
  "rewrites": [{ "source": "/((?!.*\\.).*)", "destination": "/" }],
  "headers": [
    {
      "source": "/(.*)\\.pdf",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Content-Disposition", "value": "attachment" }
      ]
    }
  ]
}
